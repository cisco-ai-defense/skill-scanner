# Skill Scanner LLM Configuration
# All LLM providers use the same SKILL_SCANNER_LLM_* variables

# Standard setup (Anthropic, OpenAI, Google AI Studio, etc.)
# SKILL_SCANNER_LLM_API_KEY=your_api_key
# SKILL_SCANNER_LLM_MODEL=claude-3-5-sonnet-20241022

# Azure OpenAI
# SKILL_SCANNER_LLM_API_KEY=your_azure_key
# SKILL_SCANNER_LLM_MODEL=azure/gpt-4.1
# SKILL_SCANNER_LLM_BASE_URL=https://your-resource.openai.azure.com/
# SKILL_SCANNER_LLM_API_VERSION=2025-01-01-preview
# SKILL_SCANNER_LLM_FORCE_JSON_OBJECT=true

# AWS Bedrock (bearer token)
# SKILL_SCANNER_LLM_API_KEY=bedrock-api-key-...
# SKILL_SCANNER_LLM_MODEL=bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0

# AWS Bedrock (IAM credentials - no API key needed)
# AWS_PROFILE=your-profile
# AWS_REGION=us-east-1
# SKILL_SCANNER_LLM_MODEL=bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0

# Google Vertex AI (service account - no API key needed)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# SKILL_SCANNER_LLM_MODEL=vertex_ai/gemini-1.5-pro

# Meta-Analyzer Configuration (optional)
# Falls back to SKILL_SCANNER_LLM_* if not set
# Use different model/key for meta-analysis "second opinion"
# SKILL_SCANNER_META_LLM_API_KEY=different_key
# SKILL_SCANNER_META_LLM_MODEL=gpt-4o
# SKILL_SCANNER_META_LLM_BASE_URL=
# SKILL_SCANNER_META_LLM_API_VERSION=

# VirusTotal Configuration (optional)
# VIRUSTOTAL_API_KEY=your_virustotal_api_key

# Cisco AI Defense Configuration (optional)
# AI_DEFENSE_API_KEY=your_aidefense_api_key
# AI_DEFENSE_API_URL=https://us.api.inspect.aidefense.security.cisco.com/api/v1

# =============================================================================
# OpenTelemetry Observability (optional) – see docs/observability.md
# Install extras first: pip install cisco-ai-skill-scanner[otel]
# =============================================================================

# Master switch – set to "true" to enable (or pass --enable-otel on the CLI)
# SKILL_SCANNER_OTEL_ENABLED=true

# --- Exporter / backend -------------------------------------------------------
# OTLP endpoint accepted by Jaeger, Tempo, Dash0, Honeycomb, Datadog, etc.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Auth headers for hosted backends (comma-separated key=value pairs)
# Dash0 example:
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer YOUR_DASH0_TOKEN
# Honeycomb example:
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_HONEYCOMB_KEY

# --- Resource attributes ------------------------------------------------------
# Human-readable service name shown in your backend UI
# OTEL_SERVICE_NAME=skill-scanner

# Extra resource labels (comma-separated key=value pairs)
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,team=security
